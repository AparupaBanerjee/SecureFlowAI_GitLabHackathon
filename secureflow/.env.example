# ──────────────────────────────────────────────────────────────────────────────
# SecureFlow Vault — environment variables
# Copy to .env:  cp .env.example .env
# docker compose up --build   (no other changes needed for local dev)
# ──────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL (used by the db service and composed into DATABASE_URL) ─────────
POSTGRES_USER=securevault
POSTGRES_PASSWORD=securevault
POSTGRES_DB=securevault

# ── Backend ────────────────────────────────────────────────────────────────────
PORT=3001

# In Docker Compose the hostname is the service name "db".
# For non-Docker local dev change "db" to "localhost".
DATABASE_URL=postgres://securevault:securevault@db:5432/securevault

NODE_ENV=development

# NOTE: JWT_SECRET is intentionally hardcoded as "secret123" in source code
# (backend/src/middleware/auth.ts) for SAST demo purposes.
# In a real app this MUST be a strong random secret provided here:
# JWT_SECRET=change-me-to-a-long-random-string

# ── Frontend (Vite dev server — Docker only) ───────────────────────────────────
# Tells the Vite proxy where to forward /api requests.
# Inside Docker Compose the backend is reachable as http://backend:<PORT>.
# Leave this unset for non-Docker local dev (falls back to http://localhost:3001).
VITE_PROXY_TARGET=http://backend:3001

# VITE_API_URL controls where the Axios client points in production builds.
# /api is handled by the nginx reverse proxy in docker-compose.prod.yml.
VITE_API_URL=/api
